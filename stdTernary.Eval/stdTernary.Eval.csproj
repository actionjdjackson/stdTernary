<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Optimize>true</Optimize>
    <AssemblyName>stdTernary.Eval</AssemblyName>
    <RootNamespace>stdTernary.Eval</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <!-- Compile the library sources directly (no BenchmarkDotNet dependency). -->
    <Compile Include="../stdTernary/**/*.cs" Exclude="../stdTernary/Program.cs;../stdTernary/obj/**;../stdTernary/bin/**" />
  </ItemGroup>
</Project>
