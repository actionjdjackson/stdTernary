{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "-c",
                "Release",
                "${workspaceFolder}/stdTernary.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "--verbosity",
                "normal",
                "${workspaceFolder}/stdTernary.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/stdTernary.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/stdTernary.sln"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "benchmark",
            "detail": "Run the BenchmarkDotNet suite interactively (pick benchmarks from the menu).",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "-c",
                "Release",
                "--project",
                "${workspaceFolder}/stdTernary/stdTernary.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "benchmark: short",
            "detail": "Run all benchmarks with fewer warmup/measure iterations (quick pass).",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "-c",
                "Release",
                "--project",
                "${workspaceFolder}/stdTernary/stdTernary.csproj",
                "--",
                "--filter",
                "*",
                "--job",
                "short"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "benchmark: full",
            "detail": "Run the entire BenchmarkDotNet suite (long).",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "-c",
                "Release",
                "--project",
                "${workspaceFolder}/stdTernary/stdTernary.csproj",
                "--",
                "--filter",
                "*"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "eval",
            "detail": "SWAR correctness fuzzing, micro-benchmarks, and Frieder figure-of-merit study.",
            "command": "dotnet",
            "type": "process",
            "args": [
                "run",
                "-c",
                "Release",
                "--project",
                "${workspaceFolder}/stdTernary.Eval/stdTernary.Eval.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
    ]
}